# Runtime workspaces: manuscripts, reports, exports, and private run data.
inbox/*
!inbox/.gitkeep
!inbox/initial_manuscripts/
inbox/initial_manuscripts/*
!inbox/initial_manuscripts/.gitkeep
workspace/*
!workspace/.gitkeep
runs/*
!runs/.gitkeep

# Local artifacts and source manuscripts.
초기 원고(input)/*
!초기 원고(input)/.gitkeep
최종 원고(output)/*
!최종 원고(output)/.gitkeep

*.hwp
*.hwpx
*.epub
*.pdf
*.docx
*.xlsx
*.xls
*.zip

# Python.
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/

# Local machine/editor.
.env
.DS_Store
Thumbs.db
.idea/
.vscode/
