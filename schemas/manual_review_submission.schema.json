{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ManualReviewSubmission",
  "type": "object",
  "required": ["schema_version", "status", "checked_axes", "passes", "findings", "remaining_risks", "final_summary"],
  "properties": {
    "schema_version": { "const": "manual_review_submission.v1" },
    "status": { "enum": ["pending", "in_progress", "complete"] },
    "reviewer": { "type": "string" },
    "reviewed_at": { "type": "string" },
    "checked_axes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["axis", "label", "status", "notes"],
        "properties": {
          "axis": { "type": "string" },
          "label": { "type": "string" },
          "status": { "enum": ["pending", "checked", "skipped"] },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "passes": {
      "type": "object",
      "required": ["pass1", "pass2", "pass3"],
      "properties": {
        "pass1": { "$ref": "#/$defs/pass_result" },
        "pass2": { "$ref": "#/$defs/pass_result" },
        "pass3": { "$ref": "#/$defs/pass_result" }
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "remaining_risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "final_summary": { "type": "string" }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "status": { "const": "complete" }
        },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "findings": {
            "items": {
              "allOf": [
                {
                  "required": ["decision", "confidence_percent", "final_priority", "fix_hint", "reader_risk"]
                },
                {
                  "if": {
                    "properties": {
                      "final_priority": { "enum": ["P0", "P1"] }
                    },
                    "required": ["final_priority"]
                  },
                  "then": {
                    "properties": {
                      "decision": { "enum": ["확정", "confirmed"] },
                      "confidence_percent": { "type": "integer", "minimum": 95, "maximum": 100 }
                    },
                    "anyOf": [
                      { "required": ["evidence"], "properties": { "evidence": { "type": "string", "minLength": 1 } } },
                      { "required": ["evidence_snippet"], "properties": { "evidence_snippet": { "type": "string", "minLength": 1 } } }
                    ],
                    "allOf": [
                      {
                        "anyOf": [
                          { "required": ["story_internal_impact"], "properties": { "story_internal_impact": { "type": "string", "minLength": 1 } } },
                          { "required": ["story_state_before"], "properties": { "story_state_before": { "type": "string", "minLength": 1 } } },
                          { "required": ["story_state_after"], "properties": { "story_state_after": { "type": "string", "minLength": 1 } } }
                        ]
                      }
                    ],
                    "not": {
                      "required": ["counter_evidence"],
                      "properties": {
                        "counter_evidence": { "type": "string", "minLength": 1 }
                      }
                    }
                  }
                }
              ]
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "pass_result": {
      "type": "object",
      "required": ["status", "notes", "completed_task_ids"],
      "properties": {
        "status": { "enum": ["pending", "completed", "skipped"] },
        "notes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "completed_task_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      },
      "additionalProperties": false
    },
    "finding": {
      "type": "object",
      "required": ["priority", "status", "category", "claim", "rationale"],
      "properties": {
        "priority": { "enum": ["P0", "P1", "P2", "P3"] },
        "status": { "enum": ["확정", "유보", "기각", "confirmed", "deferred", "rejected"] },
        "decision": { "enum": ["확정", "강등", "철회", "유보", "confirmed", "downgraded", "retracted", "deferred"] },
        "confidence_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
        "original_priority": { "enum": ["P0", "P1", "P2", "P3"] },
        "final_priority": { "enum": ["P0", "P1", "P2", "P3"] },
        "category": { "type": "string" },
        "claim": { "type": "string" },
        "rationale": { "type": "string" },
        "evidence": { "type": "string" },
        "evidence_snippet": { "type": "string" },
        "counter_evidence": { "type": "string" },
        "story_state_before": { "type": "string" },
        "story_state_after": { "type": "string" },
        "story_internal_impact": { "type": "string" },
        "fix_hint": { "type": "string" },
        "reader_risk": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
